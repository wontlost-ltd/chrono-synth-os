# ChronoSynthOS 群晖 NAS 环境配置
# 实测硬件：Pentium N3710 / 8GB / DSM 7.3 / volume2
# 使用前：cp .env.synology .env && 修改下方密钥

# ========== Node.js 版本 ==========
# 如果 Node 24 崩溃 (Illegal Instruction)，改为 22
NODE_VERSION=24

# ========== 安全密钥（必须修改！） ==========
# JWT 签名密钥（至少 32 字符，建议用 openssl rand -hex 32 生成）
CHRONO_JWT_SECRET=CHANGE-ME-use-openssl-rand-hex-32
CHRONO_JWT_ENABLED=true

# PostgreSQL 密码
PG_PASSWORD=CHANGE-ME-use-a-strong-password

# ========== 服务端口 ==========
CHRONO_PORT=3000
JAEGER_UI_PORT=16686

# ========== 日志 ==========
CHRONO_LOG_LEVEL=info
CHRONO_LOG_JSON=true

# ========== 服务器 ==========
CHRONO_SERVER_HOST=0.0.0.0
CHRONO_SERVER_PORT=3000
# 群晖公网地址（如有 DDNS 或反向代理）
# CHRONO_SERVER_PUBLIC_URL=https://your-nas.synology.me:3000

# ========== CORS ==========
# 设置为你的前端地址；如仅局域网访问可设为 true
CHRONO_CORS_ORIGIN=true
CHRONO_CORS_CREDENTIALS=false

# ========== 认证 ==========
CHRONO_AUTH_ENABLED=false

# ========== 限流 ==========
CHRONO_RATE_LIMIT_MAX=200
CHRONO_RATE_LIMIT_WINDOW_MS=60000

# ========== WebSocket ==========
CHRONO_WEBSOCKET_ENABLED=true
CHRONO_WEBSOCKET_HEARTBEAT_MS=30000

# ========== LLM 智能体 ==========
# mock = 不调用外部 API，本地模拟
CHRONO_INTELLIGENCE_PROVIDER=mock
# 如需真实 LLM：
# CHRONO_INTELLIGENCE_PROVIDER=openai
# CHRONO_INTELLIGENCE_MODEL=gpt-4o-mini
# CHRONO_INTELLIGENCE_API_KEY=sk-xxx
# CHRONO_INTELLIGENCE_BASE_URL=https://api.openai.com/v1

# ========== OTEL 追踪 ==========
OTEL_ENABLED=true

# ========== Stripe（默认关闭） ==========
CHRONO_STRIPE_ENABLED=false

# ========== 任务队列 ==========
# N3710 降低并发避免 CPU 争抢
CHRONO_QUEUE_MAX_CONCURRENT=1
CHRONO_QUEUE_POLL_INTERVAL_MS=3000

# ========== 认知参数 ==========
# N3710 环境适当降低记忆容量上限
CHRONO_COGNITION_EVICTION_MAX_MEMORY_NODES=30000

# ========== 请求配置 ==========
CHRONO_REQUEST_TIMEOUT_MS=60000
CHRONO_REQUEST_MAX_BODY_BYTES=2097152
