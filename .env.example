# ChronoSynth OS 环境变量配置
# 复制为 .env 并修改

# 数据库路径（默认 :memory:）
# CHRONO_DB_PATH=./data/chrono.db

# 日志级别：debug | info | warn | error（默认 info）
# CHRONO_LOG_LEVEL=info

# JSON 格式日志（默认 false）
# CHRONO_LOG_JSON=true

# 服务器监听地址（默认 0.0.0.0）
# CHRONO_SERVER_HOST=0.0.0.0

# 服务器端口（默认 3000）
# CHRONO_SERVER_PORT=3000

# 集成适应度阈值（默认 0.6）
# CHRONO_INTEGRATION_FITNESS=0.6

# 集成置信度阈值（默认 0.5）
# CHRONO_INTEGRATION_CONFIDENCE=0.5

# 限流：时间窗口内最大请求数（默认 100）
# CHRONO_RATE_LIMIT_MAX=100

# 限流：时间窗口毫秒数（默认 60000）
# CHRONO_RATE_LIMIT_WINDOW_MS=60000

# WebSocket 事件流开关（默认 true）
# CHRONO_WEBSOCKET_ENABLED=true

# WebSocket 心跳间隔毫秒数（默认 30000）
# CHRONO_WEBSOCKET_HEARTBEAT_MS=30000

# CORS 允许来源（默认 false 禁用；可设为 true 允许所有，或具体域名如 https://app.example.com）
# CHRONO_CORS_ORIGIN=false

# CORS 允许携带凭证（默认 false）
# CHRONO_CORS_CREDENTIALS=false

# API Key 认证开关（默认 false）
# CHRONO_AUTH_ENABLED=false

# API Key 列表（逗号分隔，仅在 CHRONO_AUTH_ENABLED=true 时生效）
# CHRONO_AUTH_API_KEYS=key1,key2

# 请求超时毫秒数（默认 30000，设为 0 禁用）
# CHRONO_REQUEST_TIMEOUT_MS=30000

# 请求体最大字节数（默认 1048576 = 1MB）
# CHRONO_REQUEST_MAX_BODY_BYTES=1048576
