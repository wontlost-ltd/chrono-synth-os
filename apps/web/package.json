{
  "name": "@chrono/web",
  "private": true,
  "version": "2.0.0",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "i18n:check": "python3 scripts/check-i18n.py --self-test && python3 scripts/check-i18n.py",
    "test": "vitest run --configLoader runner",
    "test:watch": "vitest --configLoader runner",
    "test:ops": "sh -n scripts/render-runtime-config.sh && sh -n docker-entrypoint.sh && TMP_FILE=$(mktemp) && RUNTIME_CONFIG_OUTPUT=\"$TMP_FILE\" CHRONO_WEB_API_BASE_URL=https://api.example.test CHRONO_WEB_SENTRY_DSN=https://dsn.example.test/1 CHRONO_WEB_ENVIRONMENT=staging sh scripts/render-runtime-config.sh && grep -q 'https://api.example.test' \"$TMP_FILE\" && grep -q 'staging' \"$TMP_FILE\" && rm -f \"$TMP_FILE\"",
    "lhci": "npx @lhci/cli@latest autorun",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static",
    "chromatic": "chromatic --exit-zero-on-changes"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-zone": "^2.8.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-trace-web": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@sentry/react": "^10.53.1",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-virtual": "^3.13.18",
    "d3-sankey": "^0.12.3",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "react-router-dom": "7.17.0",
    "recharts": "^3.8.1",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@chrono/contracts": "*",
    "@chrono/design-tokens": "*",
    "@chrono/kernel-testkit": "*",
    "@chrono/sync-engine": "*",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3-sankey": "^0.12.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "chromatic": "^17.0.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "storybook": "^10.4.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.6"
  }
}
