{
  "name": "chrono-synth-os",
  "version": "2.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "description": "ChronoSynth OS — 混合数字人格操作系统",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json && tsc -p tsconfig.scripts.json",
    "typecheck": "tsc --noEmit -p tsconfig.src.json && tsc --noEmit -p tsconfig.scripts.json",
    "test:unit": "node --test --test-force-exit dist/test/unit/**/*.test.js",
    "test:integration": "node --test --test-force-exit dist/test/integration/**/*.test.js",
    "test:load": "node --test --test-force-exit dist/test/load/**/*.test.js",
    "test:contract": "node --test --test-force-exit dist/test/contract/**/*.test.js",
    "test:packages": "node --test --test-force-exit packages/*/dist/**/*.test.js packages/*/dist-test/**/*.test.js",
    "test:schema-dsl-parity:simple": "npm run --workspace @wontlost-ltd/schema-dsl test:parity-simple",
    "test:schema-dsl-parity:raw": "npm run --workspace @wontlost-ltd/schema-dsl test:parity-raw",
    "test:schema-dsl-parity:desktop": "npm run --workspace @wontlost-ltd/schema-dsl test:parity-desktop",
    "test:ops": "bash -n scripts/backup_db.sh && bash -n scripts/restore_db.sh && bash -n scripts/backup_storage.sh && bash -n scripts/test_disaster_recovery.sh && bash scripts/test_disaster_recovery.sh",
    "check:forbidden-imports": "bash scripts/check-forbidden-imports.sh",
    "check:kernel-purity": "bash scripts/check-forbidden-imports.sh",
    "test": "npm run test:unit && npm run test:integration",
    "test:golden": "npm run typecheck && npm run build && npm run test && npm run test:contract && npm run test:packages && npm run test:ops && npm run check:forbidden-imports",
    "start": "node dist/main.js",
    "start:observability-worker": "node dist/main-observability-worker.js",
    "dev": "npm run build && node dist/main.js",
    "dev:observability-worker": "npm run build && node dist/main-observability-worker.js",
    "test:integration:schema-dsl": "env -u NODE_USE_SYSTEM_CA tsc -p tsconfig.integration.json && env -u NODE_USE_SYSTEM_CA node --test --test-force-exit dist/src/test/integration/schema-dsl-*.test.js"
  },
  "keywords": [
    "digital-persona",
    "hybrid-os",
    "identity"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/pg": "^8.16.0",
    "fake-indexeddb": "^6.2.5",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/websocket": "^11.2.0",
    "@node-rs/argon2": "^2.0.2",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.74.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.216.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.216.0",
    "@opentelemetry/sdk-node": "^0.216.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.7.4",
    "ioredis": "^5.9.3",
    "kafkajs": "2.2.4",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "stripe": "^22.1.0",
    "zod": "^4.3.6"
  }
}
