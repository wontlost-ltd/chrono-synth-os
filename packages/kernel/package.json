  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "chrono-synth",
    "persona",
    "domain-driven-design",
    "unit-of-work",
    "ppf",
    "ai-agent",
    "portable"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chrono-synth/chrono-synth-os.git",
    "directory": "packages/kernel"
  },
  "homepage": "https://github.com/chrono-synth/chrono-synth-os/tree/main/packages/kernel#readme",
  "publishConfig": {
    "access": "public"
  }
}
